# Frontend — variáveis de build (exemplo; não versionar valores secretos)
# Em Docker atual o Dockerfile usa VITE_API_URL=/api (proxy nginx no mesmo host).
# Quando api.businesszap.com.br estiver no ar, pode-se usar a URL absoluta da API.

VITE_API_URL=/api
# Alternativa futura:
# VITE_API_URL=https://api.businesszap.com.br/api
