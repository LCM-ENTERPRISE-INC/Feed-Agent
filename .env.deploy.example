# Domínios-alvo (sem IPs/credenciais reais)
APP_DOMAIN=businesszap.com.br
API_DOMAIN=api.businesszap.com.br
ENABLE_TLS=false

# Frontend build/nginx
# http  → NGINX_CONF=nginx.http.conf  (fase IP / pré-DNS)
# https → NGINX_CONF=nginx.https.conf (após certificados)
NGINX_CONF=nginx.http.conf

# Origins CORS (ajuste ao IP ou domínio em uso)
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# Express atrás de 1 proxy nginx
TRUST_PROXY_HOPS=1

# Schema Postgres no boot do backend:
#   push    — temporário (sem migrations versionadas; NUNCA accept-data-loss)
#   migrate — preferido em produção quando existirem prisma/migrations
#   none    — não altera schema
DATABASE_SCHEMA_MODE=push

# Secrets — preencher no host; NÃO versionar valores reais
# JWT_SECRET=
# DB_USER=
# DB_PASSWORD=
# DB_NAME=
# MONGO_USER=
# MONGO_PASSWORD=
# GEMINI_API_KEY=
