generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SystemConfig {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Administrador do sistema. Responsável por conectar o WhatsApp via Baileys,
/// submeter fontes de notícias, revisar minutas e dispará-las para seus contatos.
model User {
  id           Int       @id @default(autoincrement())
  name         String
  email        String    @unique
  passwordHash String    @map("password_hash")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  contacts          Contact[]
  drafts            Draft[]
  whatsAppInstances WhatsAppInstance[]
  campaigns         Campaign[]

  @@map("users")
}

/// Contato cadastrado pelo usuário administrador para receber o feed de notícias.
model Contact {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  phoneNumber String   @map("phone_number")
  name        String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, phoneNumber])
  @@map("contacts")
}

enum DraftStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

/// Minutas (rascunhos) geradas pelo OCR + IA, aguardando aprovação do usuário.
model Draft {
  id               Int         @id @default(autoincrement())
  userId           Int         @map("user_id")
  originalText     String      @map("original_text")
  generatedContent Json        @map("generated_content")
  imagePath        String?     @map("image_path")
  status           DraftStatus @default(PENDING)
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([status])
  @@map("drafts")
}

/// Dispositivos do WhatsApp conectados para disparo de mensagens.
model WhatsAppInstance {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  name      String   @default("Dispositivo WhatsApp")
  status    String   @default("DISCONNECTED")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("whatsapp_instances")
}

enum CampaignStatus {
  DRAFT
  PREPARING
  QUEUE_FAILED
  QUEUED
  RUNNING
  PAUSED
  COMPLETED
  PARTIAL_FAILED
  FAILED
  CANCELLED
}

enum CampaignRecipientStatus {
  PENDING
  QUEUED
  ACTIVE
  SENT
  DELIVERED
  FAILED
  SKIPPED
  CANCELLED
}

/// Persistent broadcast campaign / batch run for a user.
model Campaign {
  id                      String         @id @default(cuid())
  userId                  Int            @map("user_id")
  draftId                 Int?           @map("draft_id")
  title                   String
  status                  CampaignStatus @default(DRAFT)
  selectionMode           String         @map("selection_mode") // all | specific
  filtersJson             Json?          @map("filters_json")
  excludedIdsJson         Json?          @map("excluded_ids_json")
  contactIdsJson          Json?          @map("contact_ids_json")
  expectedRecipients      Int            @default(0) @map("expected_recipients")
  materializedRecipients  Int            @default(0) @map("materialized_recipients")
  queuedJobs              Int            @default(0) @map("queued_jobs")
  sentCount               Int            @default(0) @map("sent_count")
  deliveredCount          Int            @default(0) @map("delivered_count")
  failedCount             Int            @default(0) @map("failed_count")
  pendingCount            Int            @default(0) @map("pending_count")
  skippedCount            Int            @default(0) @map("skipped_count")
  batchSize               Int            @default(125) @map("batch_size")
  delayMs                 Int            @default(3500) @map("delay_ms")
  skipAlreadySent         Boolean        @default(true) @map("skip_already_sent")
  errorMessage            String?        @map("error_message")
  startedAt               DateTime?      @map("started_at")
  completedAt             DateTime?      @map("completed_at")
  createdAt               DateTime       @default(now()) @map("created_at")
  updatedAt               DateTime       @updatedAt @map("updated_at")

  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipients  CampaignRecipient[]

  @@index([userId, createdAt])
  @@index([userId, status])
  @@map("campaigns")
}

/// One row per campaign recipient — jobId deterministic: campaignId:contactId
model CampaignRecipient {
  id           String                  @id // campaignId:contactId
  campaignId   String                  @map("campaign_id")
  contactId    Int                     @map("contact_id")
  phoneNumber  String                  @map("phone_number")
  contactName  String                  @map("contact_name")
  status       CampaignRecipientStatus @default(PENDING)
  attempts     Int                     @default(0)
  errorMessage String?                 @map("error_message")
  bullJobId    String?                 @map("bull_job_id")
  sentAt       DateTime?               @map("sent_at")
  createdAt    DateTime                @default(now()) @map("created_at")
  updatedAt    DateTime                @updatedAt @map("updated_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, status])
  @@index([campaignId, contactId])
  @@map("campaign_recipients")
}
